pipeline {
  agent any

  options {
    buildDiscarder(logRotator(numToKeepStr: '60'))
  }

  triggers {
    cron 'H 23 * * 7'
  }

  environment {
    OPENAI_API_KEY = credentials("smart-core-openai-api-key")
  }

  stages {
    stage('test') {
      steps {
        script {
          docker.build('maven-build', '-f build/Dockerfile .').inside("-v /var/run/docker.sock:/var/run/docker.sock -u 1000:${DOCKER_GROUP_ID}") {
            maven cmd: 'clean verify ' +
                       '--settings maven/config/settings.xml ' +
                       '-P smart-core-integration-tests '

            def build = load 'build/build.groovy'
            build.mavenIssues()
            build.collectJunit('Smart Core Integration')
          }
        }
      }
    }
  }
}
